# ThesisAI — Environment Variables
# Copy this file to .env.local and fill in the values
# WAJIB: Jangan commit .env.local, pastikan ada di Vercel Dashboard

# --- Supabase ---
# Dapat dari: https://supabase.com dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service Role Key (untuk auto-confirm user, dll.) — Dapat dari halaman yang sama
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google Gemini (Primary) ---
# Dapat dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- NVIDIA NIM (Fallback #1) ---
# Daftar & dapatkan free API key: https://build.nvidia.com/explore/discover
# Rate limit ~1000 req/hari
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here

# --- OpenRouter (Fallback #2) ---
# Daftar: https://openrouter.ai/keys
# Banyak model gratis: Meta Llama, Mistral, dll.
# Lihat model gratis: https://openrouter.ai/models?order=pricing
OPENROUTER_API_KEY=your-openrouter-api-key-here

# --- Groq (Fallback #3) ---
# Daftar & dapatkan free API key: https://console.groq.com/keys
# Inference cepat untuk Llama 3, Mixtral dll.
# Rate limit ~30 req/menit (free tier)
GROQ_API_KEY=your-groq-api-key-here

# --- NextAuth.js ---
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
